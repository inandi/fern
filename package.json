{
  "name": "mango-inandi",
  "displayName": "Mango",
  "description": "Turn your codebase into a clean, interactive map. Scan once, navigate often. Indexes PHP, JS, HTML, and CSS; shows folder > file > class > method hierarchy with docblock preview and click-to-navigate.",
  "version": "1.1.3",
  "publisher": "iNandi",
  "author": {
    "name": "Gobinda Nandi",
    "email": "gobinda.nandi.public@gmail.com",
    "url": "https://inandi.github.io/portfolio/index.html"
  },
  "icon": "media/logo.jpeg",
  "repository": {
    "type": "git",
    "url": "https://github.com/iNandi/mango"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mango.generateMap",
        "title": "Mango: Generate Map"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "php-parser": "^3.1.5"
  }
}
