{
  "name": "mango",
  "displayName": "Project Mango",
  "description": "Turn your codebase into a clean, interactive map. Scan once, navigate often.",
  "version": "0.1.0",
  "publisher": "mango",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mango.generateMap",
        "title": "Mango: Generate Map"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "php-parser": "^3.1.5"
  }
}
